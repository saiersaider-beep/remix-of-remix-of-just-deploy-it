# ============================================================
# Variables d'environnement à configurer dans Vercel
# Dashboard Vercel → Project → Settings → Environment Variables
# ============================================================

# --- Supabase (côté serveur) ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...                 # = anon key
SUPABASE_ANON_KEY=eyJhbGciOi...                        # alias toléré
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...                # SECRET — server only
SUPABASE_PROJECT_ID=xxxxxxxxxxxx
SUPABASE_DB_URL=postgresql://postgres:...@db.xxx.supabase.co:5432/postgres

# --- Supabase (exposées au bundle client via Vite) ---
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...
VITE_SUPABASE_PROJECT_ID=xxxxxxxxxxxx

# --- Flutterwave ---
FLUTTERWAVE_SECRET_KEY=FLWSECK-...
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-...
FLUTTERWAVE_ENCRYPTION_KEY=...
FLUTTERWAVE_WEBHOOK_HASH=...                           # = "Secret hash" Flutterwave dashboard

# --- CinetPay (si utilisé) ---
CINETPAY_API_KEY=...
CINETPAY_SITE_ID=...
CINETPAY_SECRET_KEY=...

# --- Lovable AI Gateway (remplacer par OpenAI/Gemini direct sur Vercel) ---
# LOVABLE_API_KEY n'existe plus hors Lovable Cloud. Voir MIGRATION_GUIDE.md §AI.
OPENAI_API_KEY=sk-...
GOOGLE_GENERATIVE_AI_API_KEY=...

# --- Divers ---
NODE_ENV=production
SESSION_SECRET=change-me-min-32-chars-random-string
PUBLIC_SITE_URL=https://your-app.vercel.app
